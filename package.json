        "@types/multer": "^1.4.12",
        "@types/node": "^20.17.12",
        "@types/nodemailer": "^6.4.17",
        "@types/pg": "^8.11.10",
        "prisma": "^6.2.1",
        "rimraf": "^6.0.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.7.3"
