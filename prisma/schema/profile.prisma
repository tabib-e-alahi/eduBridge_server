model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?  @db.Text
  avatarUrl     String?
  avatarPublicId String?
  headline      String?
  skills    String[]
  location  String?
  website   String?
  linkedIn  String?
  github    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

