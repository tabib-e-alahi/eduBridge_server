        "@prisma/client": "^6.2.1",
        "bcrypt": "^5.1.1",
        "better-auth": "^1.1.13",
        "cloudinary": "^2.5.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "helmet": "^8.0.0",
        "http-status": "^1.7.4",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "multer-storage-cloudinary": "^4.0.0",
        "nodemailer": "^6.9.16",
        "pg": "^8.13.1",
        "tsup": "^8.3.5",
        "tsx": "^4.19.2",
        "zod": "^3.24.1"
    },
